# --- Django ---
DEBUG=True
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,.localhost
DATABASE_URL=postgres://pogo:pogo@localhost:5433/pogo
LANGUAGE_CODE=es
TIME_ZONE=UTC

# --- Email ---
# Por defecto consola (dev). Para Brevo, ver .env-brevo y EMAIL_URL en .env-oci.
EMAIL_URL=consolemail://

# --- Beta cerrada ---
# En dev, INVITATION_ONLY=False (signup abierto). En prod, True.
INVITATION_ONLY=False
INVITATION_EXPIRY_DAYS=14
# Base URL absoluta para enlaces de invitación en correos (requerido en prod).
INVITATION_BASE_URL=

# --- Cache ---
CACHE_URL=locmem://
