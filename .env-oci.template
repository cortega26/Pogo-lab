# ────────────────────────────────────────────────
# Pogo-lab — Variables para despliegue en OCI
# ────────────────────────────────────────────────
# Copia este archivo a .env-oci y completa los valores.
# NUNCA comitees .env-oci (está en .gitignore).
# ────────────────────────────────────────────────

# === OCI credentials (consola: Profile → API Keys) ===
# 1. Entra a https://cloud.oracle.com
# 2. Profile (esquina superior derecha) → User Settings
# 3. Anota "User OCID" → OCI_USER_OCID
# 4. Anota "Tenancy OCID" → OCI_TENANCY_OCID
# 5. API Keys → Add API Key → Pega el contenido de infra/keys/oci_api_key_public.pem
# 6. Anota el "Fingerprint" que te da → OCI_FINGERPRINT

# Tenancy OCID (lo ves en la consola, arriba en Profile → Tenancy)
OCI_TENANCY_OCID=

# User OCID (lo ves en la consola, Profile → User Settings)
OCI_USER_OCID=

# Fingerprint (lo obtienes al subir la API key pública en OCI)
OCI_FINGERPRINT=

# Ruta a la clave privada generada (ya está en infra/keys/oci_api_key.pem)
OCI_PRIVATE_KEY_PATH=./infra/keys/oci_api_key.pem

# Región de OCI (ej: eu-madrid-1, us-ashburn-1, sa-santiago-1, eu-frankfurt-1)
# Ver regiones con capa gratuita: us-ashburn-1, eu-frankfurt-1, uk-london-1
OCI_REGION=

# === Compartment (se ve en consola OCI: Identity → Compartments) ===
# Normalmente es el mismo que el tenancy para cuentas sencillas.
# Si es el mismo, copia aquí el valor de OCI_TENANCY_OCID.
OCI_COMPARTMENT_OCID=

# === VM Config (ARM Ampere A1, siempre gratuita) ===
# No tocar salvo que necesites menos recursos.
OCI_VM_SHAPE=VM.Standard.A1.Flex
OCI_VM_OCPUS=4
OCI_VM_MEMORY_GB=24
OCI_VM_DISK_GB=100
OCI_VM_DISPLAY_NAME=pogo-lab-prod
OCI_VM_OS_IMAGE=Canonical Ubuntu 22.04

# === Red ===
# Subnet pública existente o el script creará una VCN nueva
# Dejar vacío para crear automáticamente VCN + subnet
OCI_SUBNET_OCID=

# === GitHub ===
# URL del repo (formato SSH: git@github.com:usuario/pogo-lab.git)
GITHUB_REPO_URL=

# Clave privada de deploy SSH para clonar el repo (infra/keys/deploy_key)
GITHUB_DEPLOY_PRIVATE_KEY_PATH=./infra/keys/deploy_key

# === App secrets (para .env.prod en la VM) ===
APP_SECRET_KEY=
DB_PASSWORD=
ALLOWED_HOSTS=pogo-lab.tooltician.com,www.pogo-lab.tooltician.com
DOMAIN=pogo-lab.tooltician.com
DEFAULT_FROM_EMAIL=carlos@tooltician.com
